  <!-- SAF0001: Missing [ToolParameter] on [AgentTool] method -->
  <data name="SAF0001_Title" xml:space="preserve">
    <value>Agent 工具方法参数缺少 [ToolParameter] 特性</value>
  </data>
  <data name="SAF0001_MessageFormat" xml:space="preserve">
    <value>参数 '{0}'（方法 '{1}'）缺少 [ToolParameter] 特性，Agent 无法获取参数描述</value>
  </data>
  <data name="SAF0001_Description" xml:space="preserve">
    <value>所有标记 [AgentTool] 的方法参数都应添加 [ToolParameter] 特性，以便 Agent 知晓每个参数的用途。</value>
  </data>

  <!-- SAF0002: Orphan [ToolParameter] on non-[AgentTool] method -->
  <data name="SAF0002_Title" xml:space="preserve">
    <value>非 Agent 方法的参数不应使用 [ToolParameter] 特性</value>
  </data>
  <data name="SAF0002_MessageFormat" xml:space="preserve">
    <value>参数 '{0}'（方法 '{1}'）有 [ToolParameter] 特性，但该方法未标记 [AgentTool]，该特性无效</value>
  </data>
  <data name="SAF0002_Description" xml:space="preserve">
    <value>[ToolParameter] 仅在标记 [AgentTool] 的方法上有效，非 Agent 方法请移除该特性。</value>
  </data>

  <!-- CodeFix titles -->
  <data name="CodeFix_AddToolParameter" xml:space="preserve">
